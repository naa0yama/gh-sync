{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "gh-sync manifest",
	"description": "Template sync configuration for gh-sync",
	"type": "object",
	"required": ["upstream", "files"],
	"additionalProperties": false,
	"properties": {
		"upstream": {
			"type": "object",
			"required": ["repo"],
			"additionalProperties": false,
			"properties": {
				"repo": {
					"type": "string",
					"pattern": "^[a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+$",
					"description": "GitHub repository in owner/name format"
				},
				"ref": {
					"type": "string",
					"default": "main",
					"description": "Git ref (branch, tag, or commit SHA)"
				}
			}
		},
		"spec": {
			"type": "object",
			"additionalProperties": false,
			"description": "Repository settings — compatible with gh-infra Kind: Repository spec (all fields optional)",
			"properties": {
				"description": {
					"type": "string",
					"description": "Short description of the repository"
				},
				"homepage": {
					"type": "string",
					"description": "Repository homepage URL"
				},
				"visibility": {
					"type": "string",
					"enum": ["public", "private", "internal"],
					"description": "Repository visibility"
				},
				"archived": {
					"type": "boolean",
					"description": "Whether the repository is archived"
				},
				"topics": {
					"type": "array",
					"items": { "type": "string" },
					"description": "Topic tags (full list, not additive)"
				},
				"release_immutability": {
					"type": "boolean",
					"description": "Lock releases after publishing"
				},
				"label_sync": {
					"type": "string",
					"enum": ["additive", "mirror"],
					"description": "Label sync mode: additive (default) keeps unmanaged labels; mirror deletes them"
				},
				"labels": {
					"type": "array",
					"description": "Managed repository labels",
					"items": {
						"type": "object",
						"required": ["name", "color"],
						"additionalProperties": false,
						"properties": {
							"name": {
								"type": "string",
								"minLength": 1,
								"description": "Label name (unique)"
							},
							"color": {
								"type": "string",
								"pattern": "^[0-9a-fA-F]{6}$",
								"description": "Hex colour without #"
							},
							"description": {
								"type": "string",
								"description": "Human-readable description"
							}
						}
					}
				},
				"web_commit_signoff_required": {
					"type": "boolean",
					"description": "Require contributors to sign off on web-based commits"
				},
				"features": {
					"type": "object",
					"additionalProperties": false,
					"description": "Repository feature toggles",
					"properties": {
						"issues": { "type": "boolean" },
						"projects": { "type": "boolean" },
						"wiki": { "type": "boolean" },
						"discussions": { "type": "boolean" }
					}
				},
				"merge_strategy": {
					"type": "object",
					"additionalProperties": false,
					"description": "Merge strategy settings",
					"properties": {
						"allow_merge_commit": { "type": "boolean" },
						"allow_squash_merge": { "type": "boolean" },
						"allow_rebase_merge": { "type": "boolean" },
						"allow_auto_merge": {
							"type": "boolean",
							"description": "Allow auto-merge on pull requests"
						},
						"allow_update_branch": {
							"type": "boolean",
							"description": "Allow updating a pull request's branch"
						},
						"auto_delete_head_branches": { "type": "boolean" },
						"merge_commit_title": { "type": "string" },
						"merge_commit_message": { "type": "string" },
						"squash_merge_commit_title": { "type": "string" },
						"squash_merge_commit_message": { "type": "string" }
					}
				},
				"actions": {
					"type": "object",
					"additionalProperties": false,
					"description": "GitHub Actions settings (enabled must be set when any other field is present)",
					"properties": {
						"enabled": {
							"type": "boolean",
							"description": "Must be set when any other actions.* field is present"
						},
						"allowed_actions": {
							"type": "string",
							"enum": ["all", "local_only", "selected"],
							"description": "Which actions are allowed to run"
						},
						"sha_pinning_required": {
							"type": "boolean",
							"description": "Require full SHA pinning for external actions"
						},
						"workflow_permissions": {
							"type": "string",
							"enum": ["read", "write"],
							"description": "Default GITHUB_TOKEN permission level"
						},
						"can_approve_pull_requests": {
							"type": "boolean",
							"description": "Allow workflows to approve pull requests"
						},
						"selected_actions": {
							"type": "object",
							"additionalProperties": false,
							"description": "Allowed action patterns (requires allowed_actions: selected)",
							"properties": {
								"github_owned_allowed": { "type": "boolean" },
								"patterns_allowed": {
									"type": "array",
									"items": { "type": "string" }
								}
							}
						},
						"fork_pr_approval": {
							"type": "string",
							"enum": [
								"none",
								"all_external_contributors",
								"all_contributors"
							],
							"description": "Fork pull request approval policy: none / all_external_contributors / all_contributors"
						}
					}
				},
				"rulesets": {
					"type": "array",
					"description": "Repository rulesets (preferred over branch_protection)",
					"items": {
						"type": "object",
						"required": ["name"],
						"additionalProperties": false,
						"properties": {
							"name": {
								"type": "string",
								"minLength": 1,
								"description": "Unique ruleset name"
							},
							"target": {
								"type": "string",
								"enum": ["branch", "tag"],
								"description": "Whether the ruleset targets branches or tags"
							},
							"enforcement": {
								"type": "string",
								"enum": ["active", "disabled", "evaluate"],
								"description": "Enforcement level"
							},
							"bypass_actors": {
								"type": "array",
								"description": "Actors that may bypass this ruleset",
								"items": {
									"type": "object",
									"additionalProperties": false,
									"properties": {
										"role": { "type": "string" },
										"team": { "type": "string" },
										"app": { "type": "string" },
										"org-admin": { "type": "boolean" },
										"custom-role": { "type": "string" },
										"bypass_mode": {
											"type": "string",
											"enum": ["always", "pull_request", "exempt"]
										}
									}
								}
							},
							"conditions": {
								"type": "object",
								"additionalProperties": false,
								"properties": {
									"ref_name": {
										"type": "object",
										"additionalProperties": false,
										"properties": {
											"include": {
												"type": "array",
												"items": { "type": "string" }
											},
											"exclude": {
												"type": "array",
												"items": { "type": "string" }
											}
										}
									}
								}
							},
							"rules": {
								"type": "object",
								"additionalProperties": false,
								"properties": {
									"non_fast_forward": {
										"type": "boolean",
										"description": "Block force pushes"
									},
									"deletion": {
										"type": "boolean",
										"description": "Block ref deletion"
									},
									"creation": {
										"type": "boolean",
										"description": "Block ref creation"
									},
									"required_linear_history": {
										"type": "boolean",
										"description": "Require linear commit history"
									},
									"required_signatures": {
										"type": "boolean",
										"description": "Require signed commits"
									},
									"pull_request": {
										"type": "object",
										"additionalProperties": false,
										"description": "Pull request review requirements",
										"properties": {
											"required_approving_review_count": {
												"type": "integer",
												"minimum": 0,
												"description": "Number of required approving reviews"
											},
											"dismiss_stale_reviews_on_push": {
												"type": "boolean",
												"description": "Dismiss approved reviews when new commits are pushed"
											},
											"require_code_owner_review": {
												"type": "boolean",
												"description": "Require review from a code owner"
											},
											"require_last_push_approval": {
												"type": "boolean",
												"description": "Require approval of the most recent push"
											},
											"required_review_thread_resolution": {
												"type": "boolean",
												"description": "Require all review threads to be resolved before merging"
											},
											"allowed_merge_methods": {
												"type": "array",
												"items": {
													"type": "string",
													"enum": ["squash", "merge", "rebase"]
												},
												"description": "Allowed merge methods for pull requests"
											}
										}
									},
									"required_status_checks": {
										"type": "object",
										"additionalProperties": false,
										"properties": {
											"strict_required_status_checks_policy": {
												"type": "boolean"
											},
											"contexts": {
												"type": "array",
												"items": {
													"type": "object",
													"required": ["context"],
													"additionalProperties": false,
													"properties": {
														"context": { "type": "string" },
														"app": { "type": "string" }
													}
												}
											}
										}
									}
								}
							}
						}
					}
				},
				"branch_protection": {
					"type": "array",
					"description": "Classic branch protection rules (prefer rulesets for new configurations)",
					"items": {
						"type": "object",
						"required": ["pattern"],
						"additionalProperties": false,
						"properties": {
							"pattern": {
								"type": "string",
								"minLength": 1,
								"description": "Branch name pattern (unique)"
							},
							"required_reviews": { "type": "integer", "minimum": 0 },
							"dismiss_stale_reviews": { "type": "boolean" },
							"require_code_owner_reviews": { "type": "boolean" },
							"require_status_checks": {
								"type": "object",
								"additionalProperties": false,
								"properties": {
									"strict": { "type": "boolean" },
									"contexts": { "type": "array", "items": { "type": "string" } }
								}
							},
							"enforce_admins": { "type": "boolean" },
							"allow_force_pushes": { "type": "boolean" },
							"allow_deletions": { "type": "boolean" }
						}
					}
				}
			}
		},
		"files": {
			"type": "array",
			"minItems": 1,
			"description": "Synchronisation file rules (must be non-empty)",
			"items": {
				"type": "object",
				"required": ["path", "strategy"],
				"additionalProperties": false,
				"properties": {
					"path": {
						"type": "string",
						"minLength": 1,
						"description": "Destination path in the downstream repository (relative, no leading /)"
					},
					"strategy": {
						"type": "string",
						"enum": ["replace", "create_only", "delete", "patch"],
						"description": "Synchronisation strategy"
					},
					"source": {
						"type": "string",
						"minLength": 1,
						"description": "Override for the upstream source path (replace/create_only only)"
					},
					"patch": {
						"type": "string",
						"minLength": 1,
						"description": "Explicit patch file path (patch strategy only; defaults to .github/gh-sync/patches/<path>.patch)"
					}
				}
			}
		}
	}
}
